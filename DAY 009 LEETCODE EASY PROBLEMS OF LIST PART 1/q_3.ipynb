   "source": [
    "### Check the array is sorted or not."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 36,
   "id": "af57c003",
   "metadata": {},
   "outputs": [
    {
     "data": {
      "text/plain": [
       "True"
      ]
     },
     "execution_count": 36,
     "metadata": {},
     "output_type": "execute_result"
    }
   ],
   "source": [
    "arr= [1,2,3,4,4,4,4,5,6]\n",
    "\n",
    "def sort_check(array) :\n",
    "    n = len(array) \n",
    "    for i in range(0,n-1) :\n",
    "        if array[i+1] < array[i] :\n",
    "            return False \n",
    "    return True\n",
    "\n",
    "sort_check(array=arr)"
   ]
  },
